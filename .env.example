APP_NAME="TW Downloader"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-app.onrender.com

# Frontend origin for CORS — set this to your Vercel URL
FRONTEND_URL=https://your-app.vercel.app

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── Database (MySQL on Render internal network) ───────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tw
DB_USERNAME=root
DB_PASSWORD=

# ─── Cache / Session (file-based, no Redis needed for MVP) ────────────────
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# ─── Disable unused services ──────────────────────────────────────────────
MAIL_MAILER=log
BROADCAST_CONNECTION=log
